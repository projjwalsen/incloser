# =============================================================================
# admin-web environment variables
# =============================================================================
# By default, the Express admin backend is embedded directly in this Next.js
# app (see pages/api/admin-backend/[[...slug]].ts). That means YOU MUST set the
# Supabase + JWT vars below on the SAME Vercel project as admin-web for login
# to work.
#
# If you'd rather run admin-backend as a separately deployed service, set
# ADMIN_API_PROXY_TARGET below (and you can leave the backend env vars empty
# on admin-web — they'll be read on the backend project instead).
# =============================================================================

# --- Embedded backend (default) -----------------------------------------------
# Long random string ≥16 characters. Used to sign admin JWTs.
JWT_SECRET=
# Same Supabase project as the Expo app.
SUPABASE_URL=
# Service role (NOT anon!) — required to read public.admin_users.
# Supabase Dashboard → Project Settings → API → service_role (secret).
SUPABASE_SERVICE_ROLE_KEY=

# --- External backend (optional) ----------------------------------------------
# Set this to a separately-deployed admin-backend's origin (no trailing slash,
# no path). When set, /api/admin-backend/* in the browser is proxied via
# Next.js rewrites to ${ADMIN_API_PROXY_TARGET}/api/admin/* and the embedded
# Express route is bypassed.
# Example: https://incloser-admin-api.onrender.com
# ADMIN_API_PROXY_TARGET=

# --- Browser-only override (optional) -----------------------------------------
# Public URL of a deployed admin-backend, no trailing slash. When set, the
# browser will call this URL directly (CORS must allow your admin-web origin).
# Prefer ADMIN_API_PROXY_TARGET instead unless you have a reason to expose the
# backend hostname.
# NEXT_PUBLIC_ADMIN_API_BASE_URL=
