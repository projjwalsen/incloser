# Public URL of the deployed admin-backend (Express), no trailing slash.
# Example: https://incloser-admin-api.onrender.com
NEXT_PUBLIC_ADMIN_API_BASE_URL=

# Optional: used by next.config rewrites when NEXT_PUBLIC_ADMIN_API_BASE_URL is unset.
# On Vercel, set this to your hosted API if you prefer proxying via /api/admin-backend.
# ADMIN_API_PROXY_TARGET=https://incloser-admin-api.onrender.com
