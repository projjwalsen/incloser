PORT=5001
NODE_ENV=development
JWT_SECRET=change_me_change_me

# Same Supabase project as the Expo app (see app.json expo.extra). Run: npm run sync-env-from-app
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Required for admin LOGIN (reads admin_users) and for npm run create-admin:
# Supabase Dashboard → Project Settings → API → service_role (secret). Never ship to the mobile app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
